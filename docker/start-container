#!/bin/sh
set -e

# Fix permissions on writable dirs
chown -R www-data:www-data /var/www/html/storage /var/www/html/bootstrap/cache
chmod -R 775 /var/www/html/storage /var/www/html/bootstrap/cache

# Allow www-data (nginx worker) to traverse nginx temp dir
chmod 755 /var/lib/nginx
mkdir -p /var/lib/nginx/tmp/client_body
chown -R www-data:www-data /var/lib/nginx/tmp

# Cache Laravel config, routes and views for production performance
su -s /bin/sh www-data -c "php artisan config:cache"
su -s /bin/sh www-data -c "php artisan route:cache"
su -s /bin/sh www-data -c "php artisan view:cache"
su -s /bin/sh www-data -c "php artisan event:cache"

# If arguments are passed, run them instead of supervisord (e.g. php artisan horizon)
if [ $# -gt 0 ]; then
    exec "$@"
fi

# Start supervisord (nginx + php-fpm)
exec /usr/bin/supervisord -c /etc/supervisor/conf.d/supervisord.conf
